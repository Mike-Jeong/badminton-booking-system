# 관리자 로그인 비밀번호 (평문, decisions.md D-13 확정사항)
ADMIN_PASSWORD=change-me-please

# 관리자 세션 쿠키 서명용 비밀키 (ADMIN_PASSWORD와 반드시 다른 값 사용)
ADMIN_SESSION_SECRET=replace-with-a-long-random-string

# Turso(libSQL) 연결 정보
# 로컬 개발: 파일 기반 libSQL을 사용 (libsql 클라이언트가 로컬 파일 URL도 지원하므로
# 프로덕션의 Turso 원격 URL과 동일한 코드 경로를 사용한다. deployment.md 참고)
TURSO_DATABASE_URL=file:./dev.db
# 로컬 파일 DB에는 필요 없지만, 실제 Turso 원격 DB 연결 시에는 필수
TURSO_AUTH_TOKEN=

# 전화번호 phoneHash/phoneEncrypted 계산용 마스터 키 (base64, 최소 32바이트)
# 생성 예: openssl rand -base64 32
PII_SECRET_KEY=replace-with-a-base64-encoded-32-byte-key

# 클럽데이 자동 생성 크론 라우트(/api/cron/club-days) 인증용 공유 비밀키(decisions.md D-27).
# Vercel이 크론 호출 시 Authorization: Bearer {CRON_SECRET} 헤더로 자동 전송한다.
# 생성 예: openssl rand -hex 32
CRON_SECRET=replace-with-a-long-random-string
